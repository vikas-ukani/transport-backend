generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DBLINK")
}

// ─── Admin ────────────────────────────────────────────────────────────────────
model AdminUser {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String    @unique
  password    String
  role        String    @default("admin")
  photo       String?
  isActive    Boolean   @default(true)
  resetToken  String?   @map("resetToken")
  resetExpiry DateTime? @map("resetExpiry")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model User {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String   @unique
  mobile          String   @unique
  type            String   @default("driver")
  password        String
  photo           String?
  rating          Float?   @default(0.0)
  referralCode    String?
  defaultLanguage String   @default("gu")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isVerified      Boolean  @default(false)

  // Shipment details
  address   String?
  latitude  Float?
  longitude Float?

  notifications Notification[]
  posts         Post[]
  bookings      Booking[]

  // Store the latest connected socketId and deviceId from the mobile device
  socketId String? // For real-time tracking and notifications (websocket support)
  deviceId String? // Mobile device id (for push notifications, tracking, etc.)

  walletAmount      Float?              @default(0)
  walletTopups      WalletTopup[]
  walletTransaction WalletTransaction[] // Add this line to fix the error
  counterparty      WalletTransaction[] @relation("WalletCounterparty")
  driver            Driver?
  bids              BookingBid[]
  vehicles          Vehicle[]
}

model Post {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String?
  published Boolean @default(false)
  isActive  Boolean @default(false)
  userId    String? @db.ObjectId
  user      User?   @relation(fields: [userId], references: [id])

  imageIds    String[]
  likes       String[]
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Media {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  url        String
  type       String   @default("image") // e.g., "image", "video", "audio", "document"
  mimeType   String?  @default("image/jpeg") // e.g., "image/jpeg", "video/mp4", etc.
  size       Int? // Size in bytes
  uploadedAt DateTime @default(now())
}

model Video {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  thumbnail String // URL of the video thumbnail image
  url       String // Full URL of the YouTube video
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Vehicle {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  driverName    String?
  mobileNumber  String?
  rcNumber      String   @unique // Registration number, e.g., 'MH12AB1234'
  vehicleNumber String? // Registration number, e.g., 'MH12AB1234'
  rcPhotos      String[] // Photos URL of RC Book
  truckType     String // e.g., 'Flatbed', can be further normalized
  bodyType      String? // e.g., 'Open Body'
  truckLength   String? // e.g., '20 ft'
  truckHeight   String? // e.g., '8 ft'
  loadCapacity  String? // e.g., '10 tons'
  traveledInKM  String?  @default("0.0") // e.g., '125,000 Km'
  rating        Float?   @default(0.0) // e.g., 4.7
  status        String   @default("pending") // e.g., 'verified', 'pending', 'inactive'
  imageIds      String[]
  isAvailable   Boolean? @default(true)

  ownerId String? @db.ObjectId
  owner   User?   @relation(fields: [ownerId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  referralCode String?

  registrationPaid Boolean @default(false)
  // Additional commonly used fields
  isActive         Boolean @default(true)
  description      String? // Optional description/details

  vehicle Shipment[]

  // Add relation from Vehicle to Driver
  driverId    Int?
  bookings    Booking[]
  bookingBids BookingBid[]
}

model Driver {
  id            String  @id @map("_id")
  driverId      String  @unique // Unique identifier for the driver (could be employee or internal code)
  name          String
  contact       String // Contact information (e.g., mobile number)
  licenseNumber String // Driving license number
  licenseImage  String? // URL/Path to image of driving license
  location      String? // Current location or address as text (optional; use more advanced type if Geo support added)

  // One-to-one relationship: Each driver can drive only one vehicle
  vehicleId Int?   @unique
  rating    Float? @default(0.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation: Driver belongs to a User (i.e., the owner/creator of the driver)
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  bookings Booking[]
}

// Define a VehicleLocation model to track the route/history of a vehicle's locations over time.
model VehicleLocation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId Int
  latitude  Float // Latitude of vehicle's position
  longitude Float // Longitude of vehicle's position
  timestamp DateTime @default(now()) // When the vehicle was at the location
  address   String? // Optional: Human-readable address
  createdAt DateTime @default(now())
}

// Represents the customer (assumes a Customer model exists or is a type of User) 
model Booking {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingDate DateTime @default(now())
  status      String
  driverNotes String?

  // Customer details
  customerId String @db.ObjectId
  owner      User   @relation(fields: [customerId], references: [id])

  driverId String? @db.ObjectId
  driver   Driver? @relation(fields: [driverId], references: [id])

  // Shipment details
  fromAddress   String
  fromLatitude  Float?
  fromLongitude Float?

  toAddress   String
  toLatitude  Float?
  toLongitude Float?

  truckType    String
  bodyType     String
  truckLength  String?
  truckHeight  String?
  loadCapacity String?

  // Pricing & Payment
  estimatedKm        String? // Estimated distance in kilometers for the booking
  paymentStatus      String  @default("Unpaid") // e.g., "Paid", "Pending", "Failed"
  paymentAmountCents Int? // Agreed total (cents) after bid accept; charged from wallet when paid

  // Transport bidding (drivers submit prices; customer accepts one)
  biddingOpen          Boolean @default(true)
  assignedDriverUserId String? @db.ObjectId

  shipment Shipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bids      BookingBid[]
  vehicle   Vehicle?     @relation(fields: [vehicleId], references: [id])
  vehicleId String?      @db.ObjectId
}

model BookingBid {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  bookingId String  @db.ObjectId
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  driverId String @db.ObjectId
  driver   User   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  vehicleId String?  @db.ObjectId
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  amount    Int
  note      String?
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([driverId])
}

// Tracks actual execution of the shipment
model Shipment {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  shipmentStatus     String    @default("In Transit")
  actualPickupTime   DateTime?
  actualDeliveryTime DateTime?

  booking   Booking @relation(fields: [bookingId], references: [id])
  bookingId String  @db.ObjectId

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  vehicleId String  @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  type      String   @default("general") // e.g., 'general', 'booking', 'promotion', etc.
  title     String
  message   String
  payload   Json
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTopup {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id])
  amount          Int
  currency        String   @default("inr")
  status          String   @default("pending")
  remark          String
  cashFreeOrderId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
}

/// Model to track all wallet transactions, including credit and debit between users
model WalletTransaction {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  /// The user whose wallet this transaction affects (could be driver or customer)
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id]) // single relation, not duplicate

  /// If applicable, counterparty user (for P2P transfers, e.g. payment from customer to driver)
  counterpartyId String? @db.ObjectId
  counterparty   User?   @relation("WalletCounterparty", fields: [counterpartyId], references: [id])
  amount         Int
  type           String /// "credit" | "debit"
  purpose        String /// Reason, e.g. "topup", "withdraw", "ride_payment", "refund", etc.
  currency       String  @default("inr")

  referenceId String?

  /// Transaction status
  status String @default("completed") // "pending", "failed", "completed"

  /// Free-form description
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([counterpartyId])
  @@index([type])
  @@index([referenceId])
}
